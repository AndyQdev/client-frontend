# URL del backend Nest (ej.: http://localhost:3000)
API_URL=http://localhost:3001

# Secreto para revalidación (Nest -> Next)
REVALIDATE_SECRET=super-secret

# Google Maps API Key (necesaria para el LocationPicker de direcciones de clientes)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
